root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{sh,bash,toml,md,json,jsonc,js,ts,jsx,tsx,yml,yaml,html,prettierrc}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[.bash*]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[Dockerfile,*.py]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[{Makefile,makefile},*.go]
indent_style = tab
indent_size = 4
trim_trailing_whitespace = true
